generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  displayName   String?
  photoURL      String?
  role          String   @default("student")
  remoteId      String?  @unique // Firebase UID
  source        String   @default("local") // 'local' or 'firebase'
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  enrollments   Enrollment[]
  reviews       Review[]
  profile       Profile?
  following     Connection[] @relation("follower")
  followers     Connection[] @relation("following")
  feedEvents    FeedEvent[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  bio         String?
  avatar      String?
  location    String?
  skills      Skill[]
  portfolio   PortfolioItem[]
  updatedAt   DateTime @updatedAt
}

model Skill {
  id        String    @id @default(cuid())
  name      String    @unique
  profiles  Profile[]
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model FeedEvent {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  type      String   // 'follow', 'portfolio_add', 'mention', etc.
  refId     String?  // Reference to another entity (e.g., PortfolioItem id)
  payload   String   // JSON metadata
  createdAt DateTime @default(now())
}

model PortfolioItem {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  title       String
  description String?
  mediaUrl    String
  category    String?
  tags        String?  // Comma separated
  createdAt   DateTime @default(now())
}

model Category {
  id            String   @id @default(cuid())
  name          String
  type          String   // 'academy' or 'studio'
  order         Int
  subcategories String   // JSON string
  courses       Course[]
  remoteId      String?  @unique
  source        String   @default("local")
  lastSyncedAt  DateTime?
}

model Course {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  description    String
  lecturerId     String
  lecturerName   String
  lecturerAvatar String?      @default("https://cdn.flyonui.com/fy-assets/avatar/avatar-1.png")
  price          Float
  thumbnail      String
  rating         Float        @default(4.5)
  reviewsCount   Int          @default(0)
  studentsCount  Int          @default(0)
  duration       String       @default("10h")
  level          String       
  tags           String       
  status         String       
  createdAt      DateTime     @default(now())
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  lessons        Lesson[]
  enrollments    Enrollment[]
  reviews        Review[]
  remoteId       String?      @unique
  source         String       @default("local")
  lastSyncedAt   DateTime?
}

model Lesson {
  id            String   @id @default(cuid())
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id])
  title         String
  content       String
  videoUrl      String
  type          String   
  duration      String
  order         Int
  isFree        Boolean  @default(false)
  createdAt     DateTime @default(now())
  remoteId      String?  @unique
  source        String   @default("local")
  lastSyncedAt  DateTime?
}

model Enrollment {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  courseId         String
  course           Course    @relation(fields: [courseId], references: [id])
  progress         Int       @default(0)
  status           String    @default("active")
  completedLessons String    
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?
  remoteId         String?   @unique
  source           String    @default("local")
  lastSyncedAt     DateTime?
}

model Review {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  rating       Int
  comment      String
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  remoteId     String?  @unique
  source       String   @default("local")
  lastSyncedAt DateTime?
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String?      @unique
  displayName  String?
  photoURL     String?
  role         String       @default("student")
  remoteId     String?      @unique
  source       String       @default("local")
  lastSyncedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  // Relations
  profile      Profile?
  followers    Connection[] @relation("following")
  following    Connection[] @relation("follower")
  enrollments  Enrollment[]
  feedEvents   FeedEvent[]
  reviews      Review[]
  reports      Report[]     @relation("ReportedByUser")
  
  // Studio Relations
  clientProjects    Project[]     @relation("ClientProjects")
  executorProjects  Project[]     @relation("ExecutorProjects")
  services          Service[]
  applications      Application[]
  clientContracts   Contract[]    @relation("ClientContracts")
  executorContracts Contract[]    @relation("ExecutorContracts")
  assignedTasks     Task[]        @relation("AssignedTasks")
  notifications     Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // info, success, warning, error, contract, report
  title     String
  message   String
  link      String?  // Optional redirect URL
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Profile {
  id        String          @id @default(cuid())
  userId    String          @unique
  bio       String?
  avatar    String?
  location  String?
  updatedAt DateTime        @updatedAt
  portfolio PortfolioItem[]
  user      User            @relation(fields: [userId], references: [id])
  skills    Skill[]         @relation("ProfileToSkill")
}

model Skill {
  id       String    @id @default(cuid())
  name     String    @unique
  profiles Profile[] @relation("ProfileToSkill")
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  following   User     @relation("following", fields: [followingId], references: [id])
  follower    User     @relation("follower", fields: [followerId], references: [id])

  @@unique([followerId, followingId])
}

model FeedEvent {
  id        String   @id @default(cuid())
  actorId   String
  type      String
  refId     String?
  payload   String   @default("{}")
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  mediaUrl    String
  category    String?
  tags        String?
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id])
}

model Project {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String
  clientId     String
  client       User          @relation("ClientProjects", fields: [clientId], references: [id])
  executorId   String?
  executor     User?         @relation("ExecutorProjects", fields: [executorId], references: [id])
  status       String        @default("open")
  urgency      String        @default("normal")
  budget       Float         @default(0)
  tags         String        @default("[]")
  applications Application[]
  contracts    Contract[]
  tasks        Task[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  executorId  String
  executor    User     @relation(fields: [executorId], references: [id])
  price       Float
  category    String
  tags        String   @default("[]")
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
}

model Application {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  executorId  String
  executor    User     @relation(fields: [executorId], references: [id])
  coverLetter String
  bid         Float
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model Contract {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  clientId    String
  client      User     @relation("ClientContracts", fields: [clientId], references: [id])
  executorId  String
  executor    User     @relation("ExecutorContracts", fields: [executorId], references: [id])
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  milestones  String   @default("[]")
  createdAt   DateTime @default(now())
}

model Task {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  title      String
  assigneeId String?
  assignee   User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  status     String    @default("todo")
  priority   String    @default("medium")
  deadline   DateTime?
  createdAt  DateTime  @default(now())
}

model Category {
  id            String    @id @default(cuid())
  name          String
  type          String
  order         Int
  subcategories String
  courses       Course[]
}

model Course {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  description    String
  lecturerId     String
  lecturerName   String
  lecturerAvatar String?      @default("https://cdn.flyonui.com/fy-assets/avatar/avatar-1.png")
  price          Float
  thumbnail      String
  rating         Float        @default(4.5)
  reviewsCount   Int          @default(0)
  studentsCount  Int          @default(0)
  duration       String       @default("10h")
  level          String
  tags           String
  status         String
  createdAt      DateTime     @default(now())
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  enrollments    Enrollment[]
  lessons        Lesson[]
  reviews        Review[]
}

model Lesson {
  id           String    @id @default(cuid())
  courseId     String
  title        String
  content      String
  videoUrl     String
  type         String
  duration     String
  order        Int
  isFree       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  course       Course    @relation(fields: [courseId], references: [id])
}

model Enrollment {
  id               String    @id @default(cuid())
  userId           String
  courseId         String
  progress         Int       @default(0)
  status           String    @default("active")
  completedLessons String    @default("[]")
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?
  course           Course    @relation(fields: [courseId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
}

model Review {
  id           String    @id @default(cuid())
  courseId     String
  userId       String
  rating       Int
  comment      String
  isApproved   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
  course       Course    @relation(fields: [courseId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("ReportedByUser", fields: [reporterId], references: [id])
  targetType  String   // review, user, message, project
  targetId    String
  reason      String
  status      String   @default("pending") // pending, resolved, dismissed
  createdAt   DateTime @default(now())
}

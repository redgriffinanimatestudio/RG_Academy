generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String?      @unique
  displayName  String?
  photoURL     String?
  role         String       @default("student")
  remoteId     String?      @unique
  source       String       @default("local")
  lastSyncedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  followers    Connection[] @relation("following")
  following    Connection[] @relation("follower")
  enrollments  Enrollment[]
  feedEvents   FeedEvent[]
  profile      Profile?
  reviews      Review[]
}

model Profile {
  id        String          @id @default(cuid())
  userId    String          @unique
  bio       String?
  avatar    String?
  location  String?
  updatedAt DateTime        @updatedAt
  portfolio PortfolioItem[]
  user      User            @relation(fields: [userId], references: [id])
  skills    Skill[]         @relation("ProfileToSkill")
}

model Skill {
  id       String    @id @default(cuid())
  name     String    @unique
  profiles Profile[] @relation("ProfileToSkill")
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  following   User     @relation("following", fields: [followingId], references: [id])
  follower    User     @relation("follower", fields: [followerId], references: [id])

  @@unique([followerId, followingId])
}

model FeedEvent {
  id        String   @id @default(cuid())
  actorId   String
  type      String
  refId     String?
  payload   String
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])
}

model PortfolioItem {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  mediaUrl    String
  category    String?
  tags        String?
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id])
}

model Category {
  id            String    @id @default(cuid())
  name          String
  type          String
  order         Int
  subcategories String
  remoteId      String?   @unique
  source        String    @default("local")
  lastSyncedAt  DateTime?
  courses       Course[]
}

model Course {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  description    String
  lecturerId     String
  lecturerName   String
  lecturerAvatar String?      @default("https://cdn.flyonui.com/fy-assets/avatar/avatar-1.png")
  price          Float
  thumbnail      String
  rating         Float        @default(4.5)
  reviewsCount   Int          @default(0)
  studentsCount  Int          @default(0)
  duration       String       @default("10h")
  level          String
  tags           String
  status         String
  createdAt      DateTime     @default(now())
  categoryId     String
  remoteId       String?      @unique
  source         String       @default("local")
  lastSyncedAt   DateTime?
  category       Category     @relation(fields: [categoryId], references: [id])
  enrollments    Enrollment[]
  lessons        Lesson[]
  reviews        Review[]
}

model Lesson {
  id           String    @id @default(cuid())
  courseId     String
  title        String
  content      String
  videoUrl     String
  type         String
  duration     String
  order        Int
  isFree       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  remoteId     String?   @unique
  source       String    @default("local")
  lastSyncedAt DateTime?
  course       Course    @relation(fields: [courseId], references: [id])
}

model Enrollment {
  id               String    @id @default(cuid())
  userId           String
  courseId         String
  progress         Int       @default(0)
  status           String    @default("active")
  completedLessons String
  enrolledAt       DateTime  @default(now())
  completedAt      DateTime?
  remoteId         String?   @unique
  source           String    @default("local")
  lastSyncedAt     DateTime?
  course           Course    @relation(fields: [courseId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
}

model Review {
  id           String    @id @default(cuid())
  courseId     String
  userId       String
  rating       Int
  comment      String
  isApproved   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  remoteId     String?   @unique
  source       String    @default("local")
  lastSyncedAt DateTime?
  user         User      @relation(fields: [userId], references: [id])
  course       Course    @relation(fields: [courseId], references: [id])
}

{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"APP,DB\" -c \"blue,green\" \"tsx server.ts\" \"npx prisma studio\"",
    "dev:backend": "tsx server.ts",
    "dev:api": "tsx server.ts",
    "dev:client": "npx vite --force",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server.ts",
    "postinstall": "prisma generate",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "studio": "npx prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@prisma/client": "^6.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "flyonui": "^2.4.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.15",
    "i18next": "^25.8.20",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",

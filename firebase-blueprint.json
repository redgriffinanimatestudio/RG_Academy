{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string", "enum": ["student", "lecturer", "client", "executor", "admin", "manager", "moderator"] } },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "roles"]
    },
    "Course": {
      "title": "Course",
      "description": "An educational course in Academy Mode.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "lecturerId": { "type": "string" },
        "lecturerName": { "type": "string" },
        "price": { "type": "number" },
        "thumbnail": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "lecturerId", "status"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A single lesson within a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "videoUrl": { "type": "string" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "order"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "A student's enrollment in a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "progress": { "type": "number" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId"]
    },
    "Project": {
      "title": "Project",
      "description": "A professional project in Studio Mode.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "clientId": { "type": "string" },
        "executorId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "completed", "cancelled"] },
        "budget": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientId", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A professional service offered in Studio Mode.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "executorId": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "executorId", "price"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "review", "done"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "An application from an executor to a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "executorId": { "type": "string" },
        "coverLetter": { "type": "string" },
        "bid": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "executorId", "status"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz within a lesson.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lessonId": { "type": "string" },
        "questions": { "type": "array", "items": { "type": "object" } },
        "passingScore": { "type": "number" }
      },
      "required": ["lessonId", "questions"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "A course completion certificate.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "uuid": { "type": "string" },
        "issuedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "uuid"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "userId", "rating"]
    },
    "Contract": {
      "title": "Contract",
      "description": "A formal agreement between client and executor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "executorId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "disputed"] },
        "milestones": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "clientId", "executorId", "amount", "status"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A chat room for communication.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["direct", "project", "group"] },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A system notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course data."
    },
    "/courses/{courseId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons within a course."
    },
    "/courses/{courseId}/lessons/{lessonId}/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quizzes for a lesson."
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Student course enrollments."
    },
    "/certificates/{certificateId}": {
      "schema": "Certificate",
      "description": "Issued certificates."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Course reviews."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project collaboration data."
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks within a project."
    },
    "/projects/{projectId}/applications/{applicationId}": {
      "schema": "Application",
      "description": "Applications for a project."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Service marketplace data."
    },
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Project contracts."
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Chat rooms."
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "object",
      "description": "Chat messages."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}

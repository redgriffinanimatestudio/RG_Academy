{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/api/node_modules/**": true,
    "**/dist/**": true,
    "**/api/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/out/**": true,
    "**/.next/**": true,
    "**/.vercel/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/api/node_modules": true,
    "**/dist": true,
    "**/api/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/out": true,
    "**/.next": true,
    "**/api/src/schemas/generated": true,
    "**/*.log": true
  },
  "typescript.disableAutomaticTypeAcquisition": true,
  "editor.largeFileOptimizations": true,
  "git.autorefresh": false,
  "git.enabled": true
}
